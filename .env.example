# MSG91 Configuration Example
# Copy this to .env.local or .env and fill in your actual values

# ============================================
# MSG91 OTP Configuration - REQUIRED
# ============================================

# MSG91 Widget ID
# Get this from: https://www.msg91.com/app/ → OTP Verification → Widget Settings
VITE_MSG91_WIDGET_ID=36624272444f333931393831

# MSG91 Token Auth (Authentication Token)
# Get this from: https://www.msg91.com/app/ → OTP Verification → Widget Settings
VITE_MSG91_TOKEN_AUTH=497026TZDdbCze69a336a2P1

# ============================================
# MSG91 OTP Configuration - OPTIONAL
# ============================================

# Your MSG91 Template ID for OTP messages
# Get this from: https://www.msg91.com/app/setting/sms-templates
VITE_MSG91_TEMPLATE_ID=

# Default identifier (pre-fill email or mobile number)
# Example: "919999999999" or "user@example.com"
VITE_MSG91_DEFAULT_IDENTIFIER=

# Expose methods on window for custom UI
# true = use window.sendOtp, window.verifyOtp, etc.
# false = use default MSG91 widget UI
VITE_MSG91_EXPOSE_METHODS=true

# Enable/disable MSG91 OTP service
# true = use MSG91, false = use backend only
VITE_MSG91_ENABLED=true

# ============================================
# Backend Configuration (Existing)
# ============================================

# InsForge backend URL
VITE_INSFORGE_URL=https://your-app.region.insforge.app

# InsForge anonymous key
VITE_INSFORGE_ANON_KEY=your-anon-key-here

# ============================================
# Development vs Production
# ============================================

# For development, set DEBUG=true for more console logging
VITE_DEBUG=true

# ============================================
# GETTING MSG91 CREDENTIALS
# ============================================
# 
# 1. Go to: https://www.msg91.com/
# 2. Create/login to your account
# 3. Go to: Dashboard → OTP Verification → Widget Settings
# 4. Copy Widget ID and Token Auth
# 5. Paste them below
#
# Optional - SMS Template:
# 6. Go to: Dashboard → SMS Templates
# 7. Create OTP template: "Your OTP is {#var#}"
# 8. Copy template ID and paste above
#
# 9. Test Values:
#    - Mobile: 9999999999 (test number)
#    - OTP: 1234 (test OTP in development)
#
# ============================================
